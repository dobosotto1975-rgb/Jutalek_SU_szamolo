@model AdvisorDashboardApp.Models.DataEntryViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Adatfelvitel";
}

<section class="page-header">
    <div>
        <h1>Új havi adat</h1>
        <p>Rögzíts új adatot tanácsadóhoz.</p>
    </div>
</section>

<section class="panel form-card">
    <div class="panel-header">
        <h2>Adatfelvitel</h2>
    </div>

    <form asp-action="Index" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-text"></div>

        <div class="form-grid two-col">
            <div class="form-group">
                <label asp-for="AdvisorId">Tanácsadó</label>

                <select asp-for="AdvisorId" class="native-hidden-select" id="AdvisorId">
                    <option value="">-- válassz tanácsadót --</option>
                    @foreach (var item in Model.Advisors)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>

                <div class="custom-select-local" data-target="AdvisorId" data-placeholder="-- válassz tanácsadót --">
                    <button type="button" class="custom-select-trigger-local">
                        <span class="custom-select-text-local">-- válassz tanácsadót --</span>
                        <span class="custom-select-arrow-local">⌄</span>
                    </button>
                    <div class="custom-select-dropdown-local">
                        <div class="custom-select-search-wrap-local">
                            <input type="text" class="custom-select-search-local" placeholder="Keresés..." />
                        </div>
                        <div class="custom-select-options-local">
                            @foreach (var item in Model.Advisors)
                            {
                                <button type="button"
                                        class="custom-select-option-local"
                                        data-value="@item.Value"
                                        data-text="@item.Text">
                                    @item.Text
                                </button>
                            }
                        </div>
                    </div>
                </div>

                <span asp-validation-for="AdvisorId" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Year">Év</label>
                <select asp-for="Year" asp-items="Model.Years" class="input-modern"></select>
                <span asp-validation-for="Year" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Month">Hónap</label>
                <select asp-for="Month" asp-items="Model.Months" class="input-modern"></select>
                <span asp-validation-for="Month" class="validation-text"></span>
            </div>

            <div class="form-group full-width">
                <label asp-for="Product">Termék</label>

                <select asp-for="Product" class="native-hidden-select" id="Product">
                    <option value="">-- válassz terméket --</option>
                    @foreach (var item in Model.Products)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>

                <div class="custom-select-local" data-target="Product" data-placeholder="-- válassz terméket --">
                    <button type="button" class="custom-select-trigger-local">
                        <span class="custom-select-text-local">-- válassz terméket --</span>
                        <span class="custom-select-arrow-local">⌄</span>
                    </button>
                    <div class="custom-select-dropdown-local">
                        <div class="custom-select-search-wrap-local">
                            <input type="text" class="custom-select-search-local" placeholder="Keresés..." />
                        </div>
                        <div class="custom-select-options-local product-options-local">
                            @foreach (var item in Model.Products)
                            {
                                <button type="button"
                                        class="custom-select-option-local"
                                        data-value="@item.Value"
                                        data-text="@item.Text">
                                    @item.Text
                                </button>
                            }
                        </div>
                    </div>
                </div>

                <span asp-validation-for="Product" class="validation-text"></span>
            </div>

            <div class="form-group" id="ukQuestionWrap" style="display:none;">
                <label asp-for="IsUkContract">ÜK-san lett megkötve?</label>
                <select asp-for="IsUkContract" class="input-modern" id="ukSelect">
                    <option value="false">Nem</option>
                    <option value="true">Igen</option>
                </select>
            </div>

            <div class="form-group">
                <label asp-for="Amount">Állománydíj (Ft)</label>
                <input asp-for="Amount" class="input-modern" type="number" step="0.01" />
                <span asp-validation-for="Amount" class="validation-text"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Mentés</button>
        </div>
    </form>
</section>

@if (Model.Amount > 0 && !string.IsNullOrWhiteSpace(Model.Product))
{
    <section class="panel page-card" style="margin-top:24px;">
        <div class="panel-header">
            <h2>Előnézeti számolás</h2>
        </div>

        <div class="table-wrap">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>Termék</th>
                        <th>Állománydíj</th>
                        <th>Jutalék %</th>
                        <th>Osztó</th>
                        <th>Jutalék</th>
                        <th>SU</th>
                        <th>ÜK</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@Model.Product</td>
                        <td>@Model.Amount.ToString("N0") Ft</td>
                        <td>@Model.CommissionPercent.ToString("N2") %</td>
                        <td>@Model.Divider.ToString("N0")</td>
                        <td>@Model.CalculatedCommission.ToString("N0") Ft</td>
                        <td>@Model.CalculatedSu.ToString("N4")</td>
                        <td>@(Model.IsUkContract ? "Igen" : "Nem")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
}

<style>
    .native-hidden-select {
        display: none;
    }

    .custom-select-local {
        position: relative;
        width: 100%;
    }

    .custom-select-trigger-local {
        width: 100%;
        min-height: 52px;
        border-radius: 16px;
        border: 1px solid rgba(94,162,255,0.35);
        background: linear-gradient(180deg, #223056, #1b2746);
        color: #ffffff;
        padding: 0 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        cursor: pointer;
        font-size: 1rem;
        font-weight: 600;
        text-align: left;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
    }

    .custom-select-text-local {
        display: block;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
        flex: 1;
    }

    .custom-select-arrow-local {
        font-size: 1.2rem;
        color: #dbeafe;
        flex-shrink: 0;
    }

    .custom-select-dropdown-local {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        right: 0;
        z-index: 500;
        background: linear-gradient(180deg, #15203d, #11192f);
        border: 1px solid rgba(94,162,255,0.28);
        border-radius: 18px;
        box-shadow: 0 18px 40px rgba(0,0,0,0.42);
        overflow: hidden;
        display: none;
    }

    .custom-select-local.open .custom-select-dropdown-local {
        display: block;
    }

    .custom-select-search-wrap-local {
        padding: 12px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.02);
    }

    .custom-select-search-local {
        width: 100%;
        min-height: 44px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.10);
        background: #0f1730;
        color: #ffffff;
        padding: 0 14px;
        outline: none;
        font-size: 0.96rem;
    }

    .custom-select-options-local {
        max-height: 260px;
        overflow-y: auto;
        padding: 8px;
    }

    .product-options-local {
        max-height: 340px;
    }

    .custom-select-option-local {
        width: 100%;
        border: none;
        background: transparent;
        color: #eef2ff;
        text-align: left;
        padding: 12px 14px;
        border-radius: 12px;
        cursor: pointer;
        font-size: 0.95rem;
        line-height: 1.4;
        margin-bottom: 4px;
    }

        .custom-select-option-local:hover {
            background: #2e4172;
            color: #ffffff;
        }

        .custom-select-option-local.selected {
            background: #35508f;
            color: #ffffff;
            font-weight: 700;
        }

        .custom-select-option-local.hidden {
            display: none;
        }

    .custom-select-empty-local {
        padding: 12px 14px;
        color: #9fb0d1;
        font-size: 0.92rem;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const ukProducts = [
            "Vienna Yes alapdíj, ha a teljes díj  120e Ft-ig /állománydíjas/",
            "Vienna Yes alapdíj, ha a teljes díj 120-145e Ft között /állománydíjas/",
            "Vienna Yes alapdíj, ha a teljes díj 145e Ft-tól /állománydíjas/"
        ];

        const productSelect = document.getElementById("Product");
        const ukQuestionWrap = document.getElementById("ukQuestionWrap");
        const ukSelect = document.getElementById("ukSelect");

        function toggleUkQuestion() {
            const selectedProduct = productSelect.value;

            if (ukProducts.includes(selectedProduct)) {
                ukQuestionWrap.style.display = "block";
            } else {
                ukQuestionWrap.style.display = "none";
                ukSelect.value = "false";
            }
        }

        function initLocalCustomSelects() {
            const selects = document.querySelectorAll(".custom-select-local");

            selects.forEach(wrapper => {
                const targetId = wrapper.dataset.target;
                const realSelect = document.getElementById(targetId);
                const trigger = wrapper.querySelector(".custom-select-trigger-local");
                const text = wrapper.querySelector(".custom-select-text-local");
                const search = wrapper.querySelector(".custom-select-search-local");
                const options = Array.from(wrapper.querySelectorAll(".custom-select-option-local"));
                const placeholder = wrapper.dataset.placeholder || "-- válassz --";

                if (!realSelect || !trigger || !text || !search || options.length === 0) {
                    return;
                }

                syncFromRealSelect();

                trigger.addEventListener("click", function (e) {
                    e.preventDefault();
                    const isOpen = wrapper.classList.contains("open");

                    document.querySelectorAll(".custom-select-local.open").forEach(x => x.classList.remove("open"));

                    if (!isOpen) {
                        wrapper.classList.add("open");
                        search.value = "";
                        filterOptions("");
                        setTimeout(() => search.focus(), 10);
                    }
                });

                search.addEventListener("input", function () {
                    filterOptions(search.value);
                });

                options.forEach(option => {
                    option.addEventListener("click", function () {
                        const value = option.dataset.value || "";
                        const label = option.dataset.text || placeholder;

                        realSelect.value = value;
                        text.textContent = label;

                        options.forEach(o => o.classList.remove("selected"));
                        option.classList.add("selected");

                        wrapper.classList.remove("open");
                        search.value = "";
                        filterOptions("");

                        realSelect.dispatchEvent(new Event("change", { bubbles: true }));
                    });
                });

                function syncFromRealSelect() {
                    const selectedOption = realSelect.options[realSelect.selectedIndex];
                    if (selectedOption && selectedOption.value !== "") {
                        text.textContent = selectedOption.text;
                        options.forEach(o => {
                            o.classList.toggle("selected", o.dataset.value === selectedOption.value);
                        });
                    } else {
                        text.textContent = placeholder;
                        options.forEach(o => o.classList.remove("selected"));
                    }
                }

                function filterOptions(term) {
                    const normalized = (term || "").trim().toLowerCase();
                    let visibleCount = 0;

                    options.forEach(option => {
                        const content = (option.dataset.text || "").toLowerCase();
                        const visible = content.includes(normalized);
                        option.classList.toggle("hidden", !visible);
                        if (visible) visibleCount++;
                    });

                    let empty = wrapper.querySelector(".custom-select-empty-local");
                    if (visibleCount === 0) {
                        if (!empty) {
                            empty = document.createElement("div");
                            empty.className = "custom-select-empty-local";
                            empty.textContent = "Nincs találat.";
                            wrapper.querySelector(".custom-select-options-local").appendChild(empty);
                        }
                    } else if (empty) {
                        empty.remove();
                    }
                }
            });

            document.addEventListener("click", function (e) {
                if (!e.target.closest(".custom-select-local")) {
                    document.querySelectorAll(".custom-select-local.open").forEach(x => x.classList.remove("open"));
                }
            });
        }

        document.addEventListener("DOMContentLoaded", function () {
            initLocalCustomSelects();
            toggleUkQuestion();
            productSelect.addEventListener("change", toggleUkQuestion);
        });
    </script>
}