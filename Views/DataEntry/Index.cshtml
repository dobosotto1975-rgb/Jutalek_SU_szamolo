@model AdvisorDashboardApp.Models.DataEntryViewModel

@{
    ViewData["Title"] = "Adatfelvitel";
}

<div class="page-header">
    <div>
        <h1>Adatfelvitel</h1>
        <p class="muted-text">Új havi termelési adat rögzítése modern, átlátható felületen.</p>
    </div>
</div>

<section class="form-card entry-card entry-card-glow">
    <div class="entry-card-top">
        <div>
            <div class="section-badge">HAVI RÖGZÍTÉS</div>
            <h2 class="entry-title">Új termelési adat felvitele</h2>
            <p class="entry-subtitle">
                Válaszd ki a tanácsadót, a terméket, add meg az állománydíjat, és az eredmény azonnal frissül.
            </p>
        </div>
    </div>

    <form asp-action="Index" method="post" class="entry-form">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="entry-layout">
            <div class="entry-left">
                <div class="form-grid two-col">

                    <div class="form-group">
                        <label asp-for="AdvisorId">Tanácsadó</label>

                        <select asp-for="AdvisorId" asp-items="Model.Advisors" class="native-hidden-select" id="AdvisorId">
                            <option value="">Válassz tanácsadót</option>
                        </select>

                        <div class="custom-select" data-target="AdvisorId" data-placeholder="Válassz tanácsadót">
                            <button type="button" class="custom-select-trigger">
                                <span class="custom-select-text">Válassz tanácsadót</span>
                                <span class="custom-select-arrow">⌄</span>
                            </button>
                            <div class="custom-select-dropdown">
                                <div class="custom-select-search-wrap">
                                    <input type="text" class="custom-select-search" placeholder="Keresés..." />
                                </div>
                                <div class="custom-select-options">
                                    @foreach (var item in Model.Advisors)
                                    {
                                        <button type="button"
                                                class="custom-select-option"
                                                data-value="@item.Value"
                                                data-text="@item.Text">
                                            @item.Text
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <span asp-validation-for="AdvisorId" class="validation-text"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Year">Év</label>

                        <select asp-for="Year" asp-items="Model.Years" class="native-hidden-select" id="Year"></select>

                        <div class="custom-select" data-target="Year" data-placeholder="Válassz évet">
                            <button type="button" class="custom-select-trigger">
                                <span class="custom-select-text">Válassz évet</span>
                                <span class="custom-select-arrow">⌄</span>
                            </button>
                            <div class="custom-select-dropdown">
                                <div class="custom-select-search-wrap">
                                    <input type="text" class="custom-select-search" placeholder="Keresés..." />
                                </div>
                                <div class="custom-select-options">
                                    @foreach (var item in Model.Years)
                                    {
                                        <button type="button"
                                                class="custom-select-option"
                                                data-value="@item.Value"
                                                data-text="@item.Text">
                                            @item.Text
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <span asp-validation-for="Year" class="validation-text"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Month">Hónap</label>

                        <select asp-for="Month" asp-items="Model.Months" class="native-hidden-select" id="Month"></select>

                        <div class="custom-select" data-target="Month" data-placeholder="Válassz hónapot">
                            <button type="button" class="custom-select-trigger">
                                <span class="custom-select-text">Válassz hónapot</span>
                                <span class="custom-select-arrow">⌄</span>
                            </button>
                            <div class="custom-select-dropdown">
                                <div class="custom-select-search-wrap">
                                    <input type="text" class="custom-select-search" placeholder="Keresés..." />
                                </div>
                                <div class="custom-select-options">
                                    @foreach (var item in Model.Months)
                                    {
                                        <button type="button"
                                                class="custom-select-option"
                                                data-value="@item.Value"
                                                data-text="@item.Text">
                                            @item.Text
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <span asp-validation-for="Month" class="validation-text"></span>
                    </div>

                    <div class="form-group full-width">
                        <label asp-for="Product">Termék</label>

                        <select asp-for="Product" asp-items="Model.Products" class="native-hidden-select" id="Product"></select>

                        <div class="custom-select" data-target="Product" data-placeholder="Válassz terméket">
                            <button type="button" class="custom-select-trigger">
                                <span class="custom-select-text">Válassz terméket</span>
                                <span class="custom-select-arrow">⌄</span>
                            </button>
                            <div class="custom-select-dropdown">
                                <div class="custom-select-search-wrap">
                                    <input type="text" class="custom-select-search" placeholder="Keresés..." />
                                </div>
                                <div class="custom-select-options product-options">
                                    @foreach (var item in Model.Products)
                                    {
                                        <button type="button"
                                                class="custom-select-option"
                                                data-value="@item.Value"
                                                data-text="@item.Text">
                                            @item.Text
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <span asp-validation-for="Product" class="validation-text"></span>
                    </div>

                    <div class="form-group full-width">
                        <label asp-for="Amount">Állománydíj (Ft)</label>
                        <input asp-for="Amount" id="Amount" class="input-modern" type="number" step="0.01" placeholder="Például: 120000" />
                        <span asp-validation-for="Amount" class="validation-text"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ContractStartDate">Kötés kezdete</label>
                        <input asp-for="ContractStartDate" class="input-modern" type="date" />
                        <span asp-validation-for="ContractStartDate" class="validation-text"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="IsPremiumPaid">Díjrendezett?</label>
                        <select asp-for="IsPremiumPaid" class="input-modern">
                            <option value="true">Igen</option>
                            <option value="false">Nem</option>
                        </select>
                        <span asp-validation-for="IsPremiumPaid" class="validation-text"></span>
                    </div>

                    <div class="form-group full-width" id="ukQuestionWrap" style="display:none;">
                        <label asp-for="IsUkContract">ÜK-s kötés</label>
                        <select asp-for="IsUkContract" class="input-modern" id="ukSelect">
                            <option value="false">Nem</option>
                            <option value="true">Igen</option>
                        </select>
                    </div>
                </div>

                <div id="yesProductSection" class="yes-panel" style="display:none;">
                    <div class="yes-panel-header">
                        <h3>Vienna Yes kiegészítő adatok</h3>
                        <p>Csak a Vienna Yes típusú termékeknél jelenik meg.</p>
                    </div>

                    <div class="form-grid two-col">
                        <div class="form-group">
                            <label asp-for="YesFullBaseAmount">Teljes alapdíj</label>
                            <input asp-for="YesFullBaseAmount" id="YesFullBaseAmount" class="input-modern" type="number" step="0.01" />
                            <span asp-validation-for="YesFullBaseAmount" class="validation-text"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="YesFullTotalAmount">Teljes összes díj</label>
                            <input asp-for="YesFullTotalAmount" id="YesFullTotalAmount" class="input-modern" type="number" step="0.01" />
                            <span asp-validation-for="YesFullTotalAmount" class="validation-text"></span>
                        </div>

                        <div class="form-group full-width">
                            <label asp-for="YesDiscountPercent">Kedvezmény %</label>
                            <input asp-for="YesDiscountPercent" id="YesDiscountPercent" class="input-modern" type="number" step="0.01" />
                            <span asp-validation-for="YesDiscountPercent" class="validation-text"></span>
                        </div>

                        <div class="form-group">
                            <label>Kiegészítő díj</label>
                            <input id="YesFullSupplementAmount" value="@Model.YesFullSupplementAmount.ToString("0.##")" class="input-modern readonly-modern" readonly />
                        </div>

                        <div class="form-group">
                            <label>Kedvezményes alapdíj</label>
                            <input id="YesDiscountedBaseAmount" value="@Model.YesDiscountedBaseAmount.ToString("0.##")" class="input-modern readonly-modern" readonly />
                        </div>

                        <div class="form-group">
                            <label>Kedvezményes kiegészítő díj</label>
                            <input id="YesDiscountedSupplementAmount" value="@Model.YesDiscountedSupplementAmount.ToString("0.##")" class="input-modern readonly-modern" readonly />
                        </div>

                        <div class="form-group">
                            <label>Kedvezményes teljes díj</label>
                            <input id="YesDiscountedTotalAmount" value="@Model.YesDiscountedTotalAmount.ToString("0.##")" class="input-modern readonly-modern" readonly />
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary btn-large">Mentés</button>
                </div>
            </div>

            <div class="entry-right">
                <div class="result-panel">
                    <div class="result-panel-top">
                        <span class="section-badge section-badge-alt">ÉLŐ EREDMÉNY</span>
                        <h3>Számolt értékek</h3>
                    </div>

                    <div class="result-cards result-cards-single">
                        <div class="result-card">
                            <div class="result-label">Jutalék %</div>
                            <div class="result-value" id="CommissionPercent">@Model.CommissionPercent.ToString("0.##")</div>
                        </div>

                        <div class="result-card">
                            <div class="result-label">Osztó</div>
                            <div class="result-value" id="Divider">@Model.Divider.ToString("0.##")</div>
                        </div>

                        <div class="result-card result-card-accent">
                            <div class="result-label">Számolt jutalék</div>
                            <div class="result-value" id="Commission">@Model.CalculatedCommission.ToString("N0")</div>
                            <div class="result-subvalue">Ft</div>
                        </div>

                        <div class="result-card result-card-su">
                            <div class="result-label">SU</div>
                            <div class="result-value" id="Su">@Model.CalculatedSu.ToString("0.##")</div>

                            <div class="su-meter">
                                <div class="su-meter-track">
                                    <div class="su-meter-fill" id="SuMeterFill"></div>
                                </div>
                                <div class="su-meter-labels">
                                    <span>0</span>
                                    <span>4.5</span>
                                    <span>9+</span>
                                </div>
                            </div>

                            <div class="su-status" id="SuStatus">Nincs bónusz sávban</div>
                        </div>
                    </div>

                    <div class="entry-help-box">
                        <h4>Gyors segítség</h4>
                        <ul>
                            <li>4,5 SU alatt nincs plusz bónusz.</li>
                            <li>4,5 SU-tól bónuszsáv indul.</li>
                            <li>9 SU-tól a legmagasabb bónuszsáv lép életbe.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.productRules = @Html.Raw(ViewBag.ProductRulesJson ?? "{}");
    </script>
}