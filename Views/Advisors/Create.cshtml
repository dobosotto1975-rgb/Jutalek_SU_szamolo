@model Advisor
@{
    ViewData["Title"] = "Új tanácsadó";
}

<div class="page-header">
    <h1>Új tanácsadó felvitele</h1>
</div>

<section class="form-card">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-text"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="input-modern" />
                <span asp-validation-for="Name" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Phone"></label>
                <input asp-for="Phone" class="input-modern" />
            </div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="input-modern" />
            </div>

            <div class="form-group checkbox-row">
                <input asp-for="IsActive" />
                <label asp-for="IsActive"></label>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Mentés</button>
            <a asp-action="Index" class="btn-secondary">Vissza</a>
        </div>
    </form>
</section>