@model AdvisorDashboardApp.Models.MonthlyReport

@{
    ViewData["Title"] = "Új havi adat";
}

<div class="page-header">
    <h1>Új havi adat rögzítése</h1>
    <p class="muted-text">Stabil, egyszerű adatfelvitel. A jutalék és az SU automatikusan számolódik.</p>
</div>

<section class="form-card">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-text"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="AdvisorId">Tanácsadó</label>
                <select asp-for="AdvisorId" asp-items="ViewBag.AdvisorId" class="input-modern" id="AdvisorId">
                    <option value="">-- válassz tanácsadót --</option>
                </select>
                <span asp-validation-for="AdvisorId" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Year">Év</label>
                <select asp-for="Year" asp-items="ViewBag.Years" class="input-modern" id="Year">
                    <option value="">-- válassz évet --</option>
                </select>
                <span asp-validation-for="Year" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Month">Hónap</label>
                <select asp-for="Month" asp-items="ViewBag.Months" class="input-modern" id="Month">
                    <option value="">-- válassz hónapot --</option>
                </select>
                <span asp-validation-for="Month" class="validation-text"></span>
            </div>

            <div class="form-group full-width">
                <label asp-for="Product">Termék</label>
                <select asp-for="Product" asp-items="ViewBag.Products" class="input-modern" id="Product">
                    <option value="">-- válassz terméket --</option>
                </select>
                <span asp-validation-for="Product" class="validation-text"></span>
            </div>

            <div class="form-group" id="ukQuestionWrap" style="display:none;">
                <label asp-for="IsUkContract">ÜK-san lett megkötve?</label>
                <select asp-for="IsUkContract" class="input-modern" id="ukSelect">
                    <option value="false">Nem</option>
                    <option value="true">Igen</option>
                </select>
            </div>

            <div class="form-group full-width">
                <label asp-for="Amount">Állománydíj (Ft)</label>
                <input asp-for="Amount" class="input-modern calculator-input" id="Amount" type="number" step="0.01" />
                <span asp-validation-for="Amount" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Commission">Jutalék (Ft)</label>
                <input asp-for="Commission" class="input-modern calculator-output" id="Commission" readonly />
            </div>

            <div class="form-group">
                <label asp-for="Su">SU</label>
                <input asp-for="Su" class="input-modern calculator-output" id="Su" readonly />
            </div>

            <div class="form-group">
                <label asp-for="CommissionPercent">Jutalék %</label>
                <input asp-for="CommissionPercent" class="input-modern" id="CommissionPercent" readonly />
            </div>

            <div class="form-group">
                <label asp-for="Divider">Osztó</label>
                <input asp-for="Divider" class="input-modern" id="Divider" readonly />
            </div>

            <div class="form-group">
                <label asp-for="ContractStartDate">Szerződés kezdete</label>
                <input asp-for="ContractStartDate" class="input-modern" type="date" />
                <span asp-validation-for="ContractStartDate" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="IsPremiumPaid">Díjrendezett?</label>
                <div style="display:flex;align-items:center;gap:10px;min-height:50px;">
                    <input asp-for="IsPremiumPaid" type="checkbox" style="width:18px;height:18px;" />
                    <span>Igen</span>
                </div>
                <span asp-validation-for="IsPremiumPaid" class="validation-text"></span>
            </div>

            <div class="form-group full-width">
                <label asp-for="Notes">Megjegyzés</label>
                <textarea asp-for="Notes" class="input-modern" rows="4"></textarea>
                <span asp-validation-for="Notes" class="validation-text"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Mentés</button>
            <a asp-action="Index" class="btn-secondary">Vissza</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.productRules = @Html.Raw(ViewBag.ProductRulesJson ?? "{}");
    </script>
}