@model AdvisorDashboardApp.Models.AdvisorMonthlySummaryFilterViewModel
@{
    ViewData["Title"] = "Tanácsadónkénti havi összesítés";
}

<style>
    .summary-page {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .summary-hero {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 24px 26px;
        border-radius: 22px;
        background: linear-gradient(145deg, rgba(14, 24, 60, 0.96), rgba(19, 33, 78, 0.92));
        border: 1px solid rgba(120, 145, 255, 0.18);
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
    }

    .summary-title {
        margin: 0;
        font-size: 32px;
        line-height: 1.1;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: -0.02em;
    }

    .summary-subtitle {
        margin: 0;
        font-size: 14px;
        color: rgba(226, 232, 255, 0.78);
    }

    .summary-filter-card {
        padding: 22px;
        border-radius: 22px;
        background: linear-gradient(145deg, rgba(11, 19, 50, 0.97), rgba(17, 28, 68, 0.94));
        border: 1px solid rgba(116, 138, 255, 0.16);
        box-shadow: 0 16px 36px rgba(0, 0, 0, 0.25);
    }

    .summary-filter-grid {
        display: grid;
        grid-template-columns: 1.4fr 0.8fr 0.8fr auto;
        gap: 16px;
        align-items: end;
    }

    .summary-field {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .summary-label {
        font-size: 13px;
        font-weight: 700;
        color: rgba(230, 236, 255, 0.92);
        letter-spacing: 0.01em;
    }

    .summary-select {
        width: 100%;
        height: 48px;
        border-radius: 14px;
        border: 1px solid rgba(129, 149, 255, 0.20);
        background: rgba(255, 255, 255, 0.07);
        color: #ffffff;
        padding: 0 14px;
        font-size: 15px;
        font-weight: 600;
        outline: none;
        transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        box-sizing: border-box;
    }

        .summary-select:hover {
            border-color: rgba(141, 160, 255, 0.34);
            background: rgba(255, 255, 255, 0.09);
        }

        .summary-select:focus {
            border-color: rgba(133, 156, 255, 0.62);
            box-shadow: 0 0 0 4px rgba(98, 115, 255, 0.14);
            background: rgba(255, 255, 255, 0.11);
        }

        .summary-select option {
            color: #111827;
            background: #ffffff;
        }

    .summary-button-wrap {
        display: flex;
        align-items: end;
    }

    .summary-button {
        height: 48px;
        min-width: 140px;
        border: none;
        border-radius: 14px;
        padding: 0 22px;
        font-size: 14px;
        font-weight: 800;
        color: #ffffff;
        cursor: pointer;
        background: linear-gradient(135deg, #5b6cff, #7a5cff);
        box-shadow: 0 12px 24px rgba(88, 97, 255, 0.32);
        transition: transform 0.15s ease, box-shadow 0.18s ease, opacity 0.18s ease;
    }

        .summary-button:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 28px rgba(88, 97, 255, 0.38);
        }

        .summary-button:active {
            transform: translateY(0);
            opacity: 0.96;
        }

    .summary-stats-grid {
        display: grid;
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: 16px;
    }

    .summary-stat-card {
        padding: 20px 18px;
        border-radius: 20px;
        background: linear-gradient(145deg, rgba(12, 20, 52, 0.98), rgba(18, 30, 72, 0.96));
        border: 1px solid rgba(129, 149, 255, 0.14);
        box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
    }

    .summary-stat-label {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: rgba(199, 210, 254, 0.74);
        margin-bottom: 10px;
    }

    .summary-stat-value {
        font-size: 28px;
        line-height: 1.05;
        font-weight: 800;
        color: #ffffff;
        word-break: break-word;
    }

    .summary-table-card {
        padding: 20px;
        border-radius: 22px;
        background: linear-gradient(145deg, rgba(11, 19, 50, 0.97), rgba(17, 28, 68, 0.94));
        border: 1px solid rgba(116, 138, 255, 0.16);
        box-shadow: 0 16px 36px rgba(0, 0, 0, 0.25);
        overflow: hidden;
    }

    .summary-table-wrap {
        overflow-x: auto;
    }

    .summary-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        min-width: 1180px;
    }

        .summary-table thead th {
            padding: 14px 14px;
            background: rgba(255, 255, 255, 0.06);
            color: #dbe4ff;
            font-size: 13px;
            font-weight: 800;
            text-align: left;
            border-bottom: 1px solid rgba(148, 163, 184, 0.16);
            white-space: nowrap;
        }

            .summary-table thead th:first-child {
                border-top-left-radius: 14px;
            }

            .summary-table thead th:last-child {
                border-top-right-radius: 14px;
            }

        .summary-table tbody td,
        .summary-table tfoot th,
        .summary-table tfoot td {
            padding: 14px 14px;
            color: #f8fafc;
            border-bottom: 1px solid rgba(148, 163, 184, 0.10);
            white-space: nowrap;
        }

        .summary-table tbody tr:hover td {
            background: rgba(255, 255, 255, 0.035);
        }

        .summary-table tbody tr:last-child td {
            border-bottom: none;
        }

        .summary-table tfoot th,
        .summary-table tfoot td {
            background: rgba(255, 255, 255, 0.05);
            font-weight: 800;
            color: #ffffff;
            border-top: 1px solid rgba(148, 163, 184, 0.18);
            border-bottom: none;
        }

    .summary-bonus-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 62px;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 800;
        color: #ffffff;
        background: linear-gradient(135deg, rgba(91, 108, 255, 0.95), rgba(122, 92, 255, 0.95));
    }

    .summary-empty {
        padding: 36px 20px;
        text-align: center;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.04);
        color: rgba(226, 232, 255, 0.82);
        font-size: 15px;
        font-weight: 600;
    }

    @@media (max-width: 1500px) {
        .summary-stats-grid {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }
    }

    @@media (max-width: 1280px) {
        .summary-stats-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 980px) {
        .summary-filter-grid {
            grid-template-columns: 1fr 1fr;
        }

        .summary-button-wrap {
            grid-column: 1 / -1;
        }

        .summary-button {
            width: 100%;
        }

        .summary-stats-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 640px) {
        .summary-hero {
            padding: 20px 18px;
        }

        .summary-title {
            font-size: 26px;
        }

        .summary-filter-card,
        .summary-table-card {
            padding: 16px;
        }

        .summary-filter-grid {
            grid-template-columns: 1fr;
        }

        .summary-stats-grid {
            grid-template-columns: 1fr;
        }

        .summary-stat-value {
            font-size: 24px;
        }
    }
</style>

<div class="summary-page">
    <section class="summary-hero">
        <h1 class="summary-title">Tanácsadónkénti havi összesítés</h1>
        <p class="summary-subtitle">Szűrés tanácsadóra, évre és hónapra, havi és teljes állománydíj követéssel.</p>
    </section>

    <section class="summary-filter-card">
        <form method="get" asp-action="AdvisorMonthlySummary" class="summary-filter-grid">
            <div class="summary-field">
                <label class="summary-label" for="advisorId">Tanácsadó</label>
                <select id="advisorId" name="advisorId" class="summary-select" asp-items="Model.Advisors"></select>
            </div>

            <div class="summary-field">
                <label class="summary-label" for="year">Év</label>
                <select id="year" name="year" class="summary-select" asp-items="Model.Years"></select>
            </div>

            <div class="summary-field">
                <label class="summary-label" for="month">Hónap</label>
                <select id="month" name="month" class="summary-select" asp-items="Model.Months"></select>
            </div>

            <div class="summary-button-wrap">
                <button type="submit" class="summary-button">Szűrés</button>
            </div>
        </form>
    </section>

    <section class="summary-stats-grid">
        <div class="summary-stat-card">
            <div class="summary-stat-label">Bejegyzések száma</div>
            <div class="summary-stat-value">@Model.ReportCount</div>
        </div>

        <div class="summary-stat-card">
            <div class="summary-stat-label">Havi állománydíj</div>
            <div class="summary-stat-value">@Model.TotalMonthlyAmount.ToString("N0") Ft</div>
        </div>

        <div class="summary-stat-card">
            <div class="summary-stat-label">Összesített állománydíj</div>
            <div class="summary-stat-value">@Model.TotalCumulativeAmount.ToString("N0") Ft</div>
        </div>

        <div class="summary-stat-card">
            <div class="summary-stat-label">Összes SU</div>
            <div class="summary-stat-value">@Model.TotalMonthlySu.ToString("N2")</div>
        </div>

        <div class="summary-stat-card">
            <div class="summary-stat-label">Alapjutalék</div>
            <div class="summary-stat-value">@Model.TotalBaseCommission.ToString("N0") Ft</div>
        </div>

        <div class="summary-stat-card">
            <div class="summary-stat-label">Bónusz</div>
            <div class="summary-stat-value">@Model.TotalBonusAmount.ToString("N0") Ft</div>
        </div>

        <div class="summary-stat-card">
            <div class="summary-stat-label">Végső jutalék</div>
            <div class="summary-stat-value">@Model.TotalFinalCommission.ToString("N0") Ft</div>
        </div>
    </section>

    <section class="summary-table-card">
        @if (Model.Rows.Any())
        {
            <div class="summary-table-wrap">
                <table class="summary-table">
                    <thead>
                        <tr>
                            <th>Tanácsadó</th>
                            <th>Bejegyzések</th>
                            <th>Havi állománydíj</th>
                            <th>Összesített állománydíj</th>
                            <th>SU</th>
                            <th>Alapjutalék</th>
                            <th>Bónusz sáv</th>
                            <th>Bónusz</th>
                            <th>Végső jutalék</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td>@row.AdvisorName</td>
                                <td>@row.ReportCount</td>
                                <td>@row.MonthlyAmount.ToString("N0") Ft</td>
                                <td><strong>@row.CumulativeAmount.ToString("N0") Ft</strong></td>
                                <td>@row.MonthlySu.ToString("N2")</td>
                                <td>@row.BaseCommission.ToString("N0") Ft</td>
                                <td>
                                    <span class="summary-bonus-pill">@row.BonusLabel</span>
                                </td>
                                <td>@row.BonusAmount.ToString("N0") Ft</td>
                                <td><strong>@row.FinalCommission.ToString("N0") Ft</strong></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th>Mindösszesen</th>
                            <th>@Model.ReportCount</th>
                            <th>@Model.TotalMonthlyAmount.ToString("N0") Ft</th>
                            <th>@Model.TotalCumulativeAmount.ToString("N0") Ft</th>
                            <th>@Model.TotalMonthlySu.ToString("N2")</th>
                            <th>@Model.TotalBaseCommission.ToString("N0") Ft</th>
                            <th>-</th>
                            <th>@Model.TotalBonusAmount.ToString("N0") Ft</th>
                            <th>@Model.TotalFinalCommission.ToString("N0") Ft</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <div class="summary-empty">Nincs adat a kiválasztott szűrőkhöz.</div>
        }
    </section>
</div>