@model List<MonthlyReport>
@{
    ViewData["Title"] = "Havi adatok";
}

<div class="page-header">
    <h1>Havi adatok</h1>
    <div class="header-actions">
        <a class="btn-primary" asp-action="Create">Új havi adat</a>
        <a class="btn-secondary" asp-action="Summary">Összesítő</a>
    </div>
</div>

<section class="panel">
    @if (Model.Any())
    {
        <div class="table-wrap">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>Tanácsadó</th>
                        <th>Év</th>
                        <th>Hónap</th>
                        <th>Termék</th>
                        <th>Állománydíj</th>
                        <th>Jutalék</th>
                        <th>SU</th>
                        <th>Művelet</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Advisor?.Name</td>
                            <td>@item.Year</td>
                            <td>@item.Month</td>
                            <td>@item.Product</td>
                            <td>@item.Amount.ToString("N0") Ft</td>
                            <td>@item.Commission.ToString("N0") Ft</td>
                            <td>@item.Su.ToString("N4")</td>
                            <td>
                                <div class="action-buttons">
                                    <a class="btn-edit-sm" asp-action="Edit" asp-route-id="@item.Id">Szerkesztés</a>
                                    <a class="btn-danger-sm" asp-action="Delete" asp-route-id="@item.Id">Törlés</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">Még nincs rögzített havi adat.</div>
    }
</section>