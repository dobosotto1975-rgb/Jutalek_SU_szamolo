<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AdvisorDashboard</title>

    <link rel="stylesheet" href="~/css/site.css" />

</head>
<body>

    <!-- 🔥 FELSŐ SÁV -->
    <header class="topbar">
        <div class="container topbar-inner">

            <div class="brand">
                Advisor Dashboard
            </div>

            <nav class="nav">
                <a asp-controller="Home" asp-action="Index">Dashboard</a>
                <a asp-controller="DataEntry" asp-action="Index">Adatfelvitel</a>
                <a asp-controller="MonthlyReports" asp-action="Index">Riportok</a>
            </nav>

        </div>
    </header>

    <!-- 🔥 EZ A LÉNYEG: STABIL KERET -->
    <main class="main-content">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <!-- 🔥 SCRIPT -->
    <script src="~/js/site.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>